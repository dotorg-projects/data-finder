$ErrorActionPreference = 'Stop'

$coverage = [xml](Get-Content coverage.xml)
$lineRate = [double]$coverage.coverage.'line-rate'
$blockRate = [double]$coverage.coverage.'branch-rate'
$linePercentage = [math]::Round($lineRate * 100, 2)
$blockPercentage = [math]::Round($blockRate * 100, 2)

Write-Output "## Code Coverage"
Write-Output ""
Write-Output "| Metric | Value |"
Write-Output "|---|---|"
Write-Output "| Blocks | $blockPercentage% |"
Write-Output "| Lines | $linePercentage% |"

if ($lineRate -lt 0.80 -or $blockRate -lt 0.80) {
    Write-Output "| Status | ❌ Below 80% threshold |"
    Write-Host "Coverage is below the 80% threshold"
    exit 1
}

Write-Output "| Status | ✅ Passed |"
Write-Host "Coverage passed the 80% threshold"