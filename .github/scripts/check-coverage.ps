$coverage = [xml](Get-Content coverage.xml)
$lineRate = [double]$coverage.coverage.'line-rate'
$blockRate = [double]$coverage.coverage.'branch-rate'
$linePercentage = [math]::Round($lineRate * 100, 2)
$blockPercentage = [math]::Round($blockRate * 100, 2)

Add-Content -Path $env:GITHUB_STEP_SUMMARY -Value "## Code Coverage"
Add-Content -Path $env:GITHUB_STEP_SUMMARY -Value ""
Add-Content -Path $env:GITHUB_STEP_SUMMARY -Value "| Metric | Value |"
Add-Content -Path $env:GITHUB_STEP_SUMMARY -Value "|---|---|"
Add-Content -Path $env:GITHUB_STEP_SUMMARY -Value "| Blocks | $blockPercentage% |"
Add-Content -Path $env:GITHUB_STEP_SUMMARY -Value "| Lines | $linePercentage% |"

if ($lineRate -lt 0.80 -or $blockRate -lt 0.80) {
    Add-Content -Path $env:GITHUB_STEP_SUMMARY -Value "| Status | ❌ Below 80% threshold |"
    Write-Host "Coverage is below the 80% threshold"
    exit 1
}

Add-Content -Path $env:GITHUB_STEP_SUMMARY -Value "| Status | ✅ Passed |"
Write-Host "Coverage passed the 80% threshold"