Write-Host "Summary path: $SummaryPath"
Write-Host "Coverage xml exists: $(Test-Path coverage.xml)"

param([string]$SummaryPath)
$ErrorActionPreference = 'Stop'

$coverage = [xml](Get-Content coverage.xml)
$lineRate = [double]$coverage.coverage.'line-rate'
$blockRate = [double]$coverage.coverage.'branch-rate'
$linePercentage = [math]::Round($lineRate * 100, 2)
$blockPercentage = [math]::Round($blockRate * 100, 2)
$status = if ($lineRate -lt 0.80 -or $blockRate -lt 0.80) { "❌ Below 80% threshold" } else { "✅ Passed" }

Add-Content -Path $SummaryPath -Value "## Code Coverage"
Add-Content -Path $SummaryPath -Value ""
Add-Content -Path $SummaryPath -Value "| Metric | Value |"
Add-Content -Path $SummaryPath -Value "|---|---|"
Add-Content -Path $SummaryPath -Value "| Blocks | $blockPercentage% |"
Add-Content -Path $SummaryPath -Value "| Lines | $linePercentage% |"
Add-Content -Path $SummaryPath -Value "| Status | $status |"

if ($lineRate -lt 0.80 -or $blockRate -lt 0.80) { exit 1 }
